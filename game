<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hangman Game</title>
  <style>
    :root {
      --bg: #f4f7fb;
      --card: #ffffff;
      --text: #1f2937;
      --muted: #6b7280;
      --accent: #2563eb;
      --good: #15803d;
      --bad: #dc2626;
      --line: #dbe3ee;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: linear-gradient(135deg, #eaf2ff, #f8fbff);
      color: var(--text);
      min-height: 100vh;
      display: grid;
      place-items: center;
      padding: 20px;
    }

    .game {
      width: min(700px, 100%);
      background: var(--card);
      border-radius: 18px;
      box-shadow: 0 10px 30px rgba(0,0,0,.08);
      padding: 24px;
    }

    h1 {
      text-align: center;
      margin: 0 0 20px;
      font-size: 2rem;
    }

    .top {
      display: grid;
      grid-template-columns: 180px 1fr;
      gap: 24px;
      align-items: center;
    }

    .drawing {
      width: 180px;
      height: 220px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #f9fbff;
      display: grid;
      place-items: center;
      margin: 0 auto;
    }

    svg {
      width: 140px;
      height: 200px;
      stroke: #334155;
      stroke-width: 4;
      fill: none;
      stroke-linecap: round;
      stroke-linejoin: round;
    }